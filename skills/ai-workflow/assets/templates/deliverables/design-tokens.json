{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "W3C Design Tokens example. Stack-agnostic. Replace placeholder values with real ones from VISUAL-IDENTITY.md.",
  "color": {
    "$description": "Brand and semantic colors. Primitives live in `brand`; semantic roles alias them with {color.brand.*} so themes stay swappable (per VISUAL-IDENTITY.md).",
    "brand": {
      "500": {
        "$type": "color",
        "$value": "#3B82F6",
        "$description": "Primary brand primitive."
      },
      "900": {
        "$type": "color",
        "$value": "#1E3A8A",
        "$description": "Dark brand primitive."
      },
      "accent": {
        "$type": "color",
        "$value": "#6366F1",
        "$description": "Accent primitive."
      }
    },
    "primary": {
      "$type": "color",
      "$value": "{color.brand.500}",
      "$description": "Main brand color — primary actions and key accents."
    },
    "secondary": {
      "$type": "color",
      "$value": "{color.brand.accent}"
    },
    "surface": {
      "$type": "color",
      "$value": "#FFFFFF",
      "$description": "Default background for cards and containers."
    },
    "text": {
      "$type": "color",
      "$value": "#0F172A",
      "$description": "Default body text on surface."
    },
    "success": {
      "$type": "color",
      "$value": "#16A34A"
    },
    "warning": {
      "$type": "color",
      "$value": "#D97706"
    },
    "error": {
      "$type": "color",
      "$value": "#DC2626"
    }
  },
  "font": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["Inter", "system-ui", "sans-serif"]
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "monospace"]
      }
    },
    "size": {
      "$description": "Type scale (ratio ~1.25).",
      "body": { "$type": "dimension", "$value": "16px" },
      "heading": { "$type": "dimension", "$value": "32px" },
      "display": { "$type": "dimension", "$value": "48px" },
      "caption": { "$type": "dimension", "$value": "13px" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    }
  },
  "spacing": {
    "$description": "Base-4 spacing scale.",
    "xs": { "$type": "dimension", "$value": "4px" },
    "sm": { "$type": "dimension", "$value": "8px" },
    "md": { "$type": "dimension", "$value": "16px" },
    "lg": { "$type": "dimension", "$value": "24px" },
    "xl": { "$type": "dimension", "$value": "48px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "$description": "Elevation shadows.",
    "sm": {
      "$type": "shadow",
      "$value": {
        "color": "#0F172A1A",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px",
        "inset": false
      }
    },
    "md": {
      "$type": "shadow",
      "$value": {
        "color": "#0F172A26",
        "offsetX": "0px",
        "offsetY": "4px",
        "blur": "8px",
        "spread": "0px",
        "inset": false
      }
    }
  },
  "duration": {
    "$description": "Motion durations (framer-motion / transitions). Token-driven so motion stays consistent and SEO-safe.",
    "fast": { "$type": "duration", "$value": "120ms" },
    "base": { "$type": "duration", "$value": "200ms" },
    "slow": { "$type": "duration", "$value": "320ms" }
  },
  "easing": {
    "$description": "Easing curves for motion (cubic-bezier control points).",
    "standard": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
    "emphasized": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] }
  },
  "transition": {
    "$description": "Composite motion tokens referencing duration + easing — ready to consume in framer-motion / CSS transitions.",
    "standard": {
      "$type": "transition",
      "$value": { "duration": "{duration.base}", "delay": "0ms", "timingFunction": "{easing.standard}" }
    },
    "enter": {
      "$type": "transition",
      "$value": { "duration": "{duration.fast}", "delay": "0ms", "timingFunction": "{easing.emphasized}" }
    },
    "exit": {
      "$type": "transition",
      "$value": { "duration": "{duration.fast}", "delay": "0ms", "timingFunction": "{easing.standard}" }
    }
  },
  "zIndex": {
    "$description": "Stacking order for layered UI (dropdowns, modals, toasts). NOTE: `$type: number` is a custom (non-DTCG) type; Style Dictionary v4+ handles it, and the `$extensions` hint records the integer intent.",
    "base": { "$type": "number", "$value": 0, "$extensions": { "org.tokens.type": "integer" } },
    "dropdown": { "$type": "number", "$value": 1000, "$extensions": { "org.tokens.type": "integer" } },
    "modal": { "$type": "number", "$value": 1300, "$extensions": { "org.tokens.type": "integer" } },
    "toast": { "$type": "number", "$value": 1500, "$extensions": { "org.tokens.type": "integer" } }
  }
}
